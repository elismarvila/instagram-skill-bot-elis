# Token de acesso da Meta (Instagram Graph API)
# NUNCA commite o valor real — use variáveis de ambiente na Vercel
META_ACCESS_TOKEN=SEU_TOKEN_AQUI

# ID do usuário do Instagram (numérico, ex: 17841400000000000)
IG_USER_ID=SEU_IG_USER_ID_AQUI

# Token que você inventou para verificar o webhook (qualquer string secreta)
WEBHOOK_VERIFY_TOKEN=minha_chave_secreta_123

# Link que será enviado na DM
SKILLS_LINK=https://drive.google.com/drive/folders/1JxItW8Ihe089vtYXinIcIPwlSaQO2ug9?usp=sharing

# (Opcional) ID numérico do post específico para filtrar — deixe vazio para todos os posts
TARGET_POST_ID=
